<?xml version="1.0" encoding="utf-8" ?>
<log4net>

	<!-- Info appender -->
	<appender name="InfoFileAppender" type="log4net.Appender.RollingFileAppender">
		<file value="../../app_data/logs/ai.service/debug-info.log" />
		<appendToFile value="true" />
		<rollingStyle value="Size" />
		<maximumFileSize value="1MB" />
		<maxSizeRollBackups value="10" />
		<staticLogFileName value="true" />
		<layout type="log4net.Layout.PatternLayout">
			<!-- Use %level to render the level (INFO/WARN/ERROR) -->
			<conversionPattern value="%date [%thread] %level %message%newline" />
		</layout>
		<!-- Only pass INFO-level events -->
		<filter type="log4net.Filter.LevelRangeFilter">
			<levelMin value="INFO" />
			<levelMax value="INFO" />
		</filter>
		<filter type="log4net.Filter.DenyAllFilter" />
	</appender>

	<!-- Warn appender -->
	<appender name="WarningFileAppender" type="log4net.Appender.RollingFileAppender">
		<file value="../../app_data/logs/ai.service/warnings.log" />
		<appendToFile value="true" />
		<rollingStyle value="Size" />
		<maximumFileSize value="1MB" />
		<maxSizeRollBackups value="10" />
		<staticLogFileName value="true" />
		<layout type="log4net.Layout.PatternLayout">
			<conversionPattern value="%date [%thread] %level %message%newline" />
		</layout>
		<!-- Only pass WARN-level events -->
		<filter type="log4net.Filter.LevelRangeFilter">
			<levelMin value="WARN" />
			<levelMax value="WARN" />
		</filter>
		<filter type="log4net.Filter.DenyAllFilter" />
	</appender>

	<!-- Error appender -->
	<appender name="ErrorFileAppender" type="log4net.Appender.RollingFileAppender">
		<file value="../../app_data/logs/ai.service/errors.log" />
		<appendToFile value="true" />
		<rollingStyle value="Size" />
		<maximumFileSize value="1MB" />
		<maxSizeRollBackups value="10" />
		<staticLogFileName value="true" />
		<layout type="log4net.Layout.PatternLayout">
			<conversionPattern value="%date [%thread] %level %message%newline" />
		</layout>
		<!-- Only pass ERROR-level events -->
		<filter type="log4net.Filter.LevelRangeFilter">
			<levelMin value="ERROR" />
			<levelMax value="ERROR" />
		</filter>
		<filter type="log4net.Filter.DenyAllFilter" />
	</appender>

	<!-- Define the logger named "MainLogger" and attach all three appenders -->
	<logger name="MainLogger" additivity="false">
		<level value="ALL" />
		<appender-ref ref="InfoFileAppender" />
		<appender-ref ref="WarningFileAppender" />
		<appender-ref ref="ErrorFileAppender" />
	</logger>

	<!-- Optional: root logger if you also want global logging -->
	<!--
  <root>
    <level value="WARN" />
    <appender-ref ref="ErrorFileAppender" />
  </root>
  -->

</log4net>