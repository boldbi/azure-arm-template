@{
    var isConsoleLogEnabled = !string.IsNullOrWhiteSpace(Environment.GetEnvironmentVariable(BoldServicesEnvironmentVariables.IsConsoleLogEnabled)) ? Convert.ToBoolean(Environment.GetEnvironmentVariable(BoldServicesEnvironmentVariables.IsConsoleLogEnabled)): false;
    var helpUrl = await HelpSiteManager.GetHelpSiteUrl(HelpSiteUrlNames.DiagnosticHelpUrl, TenantType.BoldBIOnPremise);
}
<script nonce="@Context.Items["ScriptNonce"]">
    var getDiagnosticLogsUrl = "@Url.Action("GetDiagnosticLogs", "Administration")";
</script>
<div id="download-logs-dialog-content" class="custom-template"></div>
<div id="download-logs-dialog" class="" style="visibility: hidden">
    @if(!isConsoleLogEnabled)
    {
        <p>@T[$"Please note that these logs only contain diagnostic logs required for {AppBranding.Bold.ProductName} and {AppBranding.BoldReports.ProductName} applications, and do not contain any of your organizational data. When reporting product-related issues, kindly download and attach the logs to your support ticket."]</p>
        <div id="download-logs-dialog-dropdown-container" class="col-12 float-start">
            @Html.Label("download-logs-dialog-dropdown", "Select a time period", new { @class = "col-12 float-start download-logs-dialog-dropdown-label" })
            @Html.DropDownList("download-logs-dialog-dropdown", new List<SelectListItem>
               {
            new SelectListItem{Text="All", Value=((int)(Interval.All)).ToString(), Selected = true},
            new SelectListItem{Text="Last 1 Hour", Value=((int)(Interval.Last1Hour)).ToString()},
            new SelectListItem{Text="Last 24 Hours", Value=((int)(Interval.Last24Hours)).ToString()},
            new SelectListItem{Text="Last 7 Days", Value=((int)(Interval.Last7Days)).ToString()},}, new { id = "download-logs-dialog-dropdown", @class = "col-12 float-start", data_live_search = "false" })
            <div>
                @Html.CheckBox("is-include-configuration", new { @class = "material-checkbox", @id = "is-include-configuration" })
                @Html.Label("is-include-configuration",T["Include configuration files"].Value)
            </div>
        </div>
    }
    else
    {
        <div id="download-configuration-file-container" class="" style="">
            <div id="download-conf-content-container">
                <p>@T[$"Diagnostic logs cannot be downloaded because the system running without a persistent storage volume. Logs are currently being streamed  to Kubernetes console."]</p>
                <p class="secodary-element">@T[$"You can still download the configuration files."]</p>
            </div>
            <div id="download-conf-content-query-container">
                <p id="download-conf-content-query-element">@T[$"Where can I find diagnostic logs?"]</p>
                <p class="secodary-element">
                    @T["You can view live logs through your platform tools. Refer the {0} for more details.",
                    Html.Raw(string.Format($"<a target=\"_blank\" href=\"{helpUrl}\">article</a>"))]
                </p>
            </div>
        </div>
    }
    <div id="download-logs-dialog-buttons" class="col-12 float-start">
        <button id="download-logs-dialog-cancel" class="secondary-button float-end">@T["Cancel"]</button>
        <button id="download-logs-dialog-proceed" class="primary-button float-end">@(isConsoleLogEnabled ? T["Download Configuration Files"] : T["Download Diagnostic Logs"])</button>
</div>
</div>
