msgid "Returns the value from a specified subsequent row in the result set relative to the current row."
msgstr "החזרת הערך משורה עוקבת שצוינה בערכת התוצאות ביחס לשורה הנוכחית."

#: App.LocalizationContent.expressionDesigner.expressionHelper.nextValueEx
msgid "NEXTVALUE(expression, offset)"
msgstr "NEXTVALUE (ביטוי, היסט)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.countPartitionDesc
msgid "Returns the count of rows for the given column or expression within a partition. Rows can be grouped using PartitionBy, ordered with OrderBy, and restricted to a specific range using Frame."
msgstr "החזרת ספירת השורות עבור העמודה או הביטוי הנתונים בתוך מחיצה. ניתן לקבץ שורות באמצעות PartitionBy, לסדר אותן באמצעות OrderBy ולהגביל לטווח ספציפי באמצעות Frame."

#: App.LocalizationContent.expressionDesigner.expressionHelper.countPartitionEx
msgid "COUNTPARTITION(expression, PartitionBy := columns)"
msgstr "COUNTPARTITION(ביטוי, PartitionBy := עמודות)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.sumPartitionDesc
msgid "Returns the sum of values for the given column or expression within a partition. Rows can be grouped using PartitionBy, ordered with OrderBy, and restricted to a specific range using Frame."
msgstr "הפונקציה מחזירה את סכום הערכים עבור העמודה או הביטוי הנתונים בתוך מחיצה. ניתן לקבץ שורות באמצעות PartitionBy, לסדר אותן באמצעות OrderBy ולהגביל לטווח ספציפי באמצעות Frame."

#: App.LocalizationContent.expressionDesigner.expressionHelper.sumPartitionEx
msgid "SUMPARTITION(expression, PartitionBy := columns)"
msgstr "SUMPARTITION(ביטוי, PartitionBy := עמודות)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.avgPartitionDesc
msgid "Returns the average of rows for the given column or expression within a partition. Rows can be grouped using PartitionBy, ordered with OrderBy, and restricted to a specific range using Frame."
msgstr "החזרת ממוצע השורות עבור העמודה או הביטוי הנתונים בתוך מחיצה. ניתן לקבץ שורות באמצעות PartitionBy, לסדר אותן באמצעות OrderBy ולהגביל לטווח ספציפי באמצעות Frame."

#: App.LocalizationContent.expressionDesigner.expressionHelper.avgPartitionEx
msgid "AVGPARTITION(expression, PartitionBy := columns)"
msgstr "AVGPARTITION(ביטוי, PartitionBy := עמודות)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.minPartitionDesc
msgid "Returns the minimum value of the given column or expression within a partition. Rows can be grouped using PartitionBy, ordered with OrderBy, and restricted to a specific range using Frame."
msgstr "החזרת הערך המינימלי של העמודה או הביטוי הנתונים בתוך מחיצה. ניתן לקבץ שורות באמצעות PartitionBy, לסדר אותן באמצעות OrderBy ולהגביל לטווח ספציפי באמצעות Frame."

#: App.LocalizationContent.expressionDesigner.expressionHelper.minPartitionEx
msgid "MINPARTITION(expression, PartitionBy := columns)"
msgstr "MINPARTITION(ביטוי, PartitionBy := עמודות)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.maxPartitionDesc
msgid "Returns the maximum value of the given column or expression within a partition. Rows can be grouped using PartitionBy, ordered with OrderBy, and restricted to a specific range using Frame."
msgstr "החזרת הערך המרבי של העמודה או הביטוי הנתונים בתוך מחיצה. ניתן לקבץ שורות באמצעות PartitionBy, לסדר אותן באמצעות OrderBy ולהגביל לטווח ספציפי באמצעות Frame."

#: App.LocalizationContent.expressionDesigner.expressionHelper.maxPartitionEx
msgid "MAXPARTITION(expression, PartitionBy := columns)"
msgstr "MAXPARTITION(ביטוי, PartitionBy := עמודות)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.rowNumerDesc
msgid "Returns the sequential number of a row within a partition, based on the specified OrderBy. Rows can be grouped using PartitionBy and ordered with OrderBy, and each row receives a unique number starting from 1."
msgstr "החזרת המספר הרציף של שורה בתוך מחיצה, בהתבסס על ה- OrderBy שצוין. ניתן לקבץ שורות באמצעות PartitionBy ולהזמין אותן באמצעות OrderBy, וכל שורה מקבלת מספר ייחודי החל מ- 1."

#: App.LocalizationContent.expressionDesigner.expressionHelper.rowNumerex
msgid "ROWNUMBER(PartitionBy := columns,OrderBy:= columns)"
msgstr "ROWNUMBER(PartitionBy:= עמודות,OrderBy:= עמודות)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.denseRankDesc
msgid "Returns the rank of a row within a partition, based on the specified OrderBy. Rows can be grouped using PartitionBy and ordered with OrderBy. Equal values receive the same rank, but no gaps are left in the ranking sequence."
msgstr "הפונקציה מחזירה את הדירוג של שורה בתוך מחיצה, בהתבסס על ה- OrderBy שצוין. ניתן לקבץ שורות באמצעות PartitionBy ולהזמין אותן באמצעות OrderBy. ערכים שווים מקבלים את אותו דירוג, אך לא נשארים פערים ברצף הדירוג."

#: App.LocalizationContent.expressionDesigner.expressionHelper.denseRankEx
msgid "DENSERANK(PartitionBy:= columns, OrderBy:= columns)"
msgstr "DENSERANK(PartitionBy:= עמודות, OrderBy:= עמודות)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.rankDesc
msgid "Returns the rank of a row within a partition, based on the specified OrderBy. Rows can be grouped using PartitionBy and ordered with OrderBy. Equal values receive the same rank, and gaps are left in the ranking sequence."
msgstr "הפונקציה מחזירה את הדירוג של שורה בתוך מחיצה, בהתבסס על ה- OrderBy שצוין. ניתן לקבץ שורות באמצעות PartitionBy ולהזמין אותן באמצעות OrderBy. ערכים שווים מקבלים את אותו דירוג, ונשארים פערים ברצף הדירוג."

#: App.LocalizationContent.expressionDesigner.expressionHelper.rankEx
msgid "RANK(PartitionBy := columns,OrderBy:= columns)"
msgstr "RANK(PartitionBy:= עמודות,OrderBy:= עמודות)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.ntileDesc
msgid "Distributes the rows within a partition into a specified number of groups (tiles), based on the specified OrderBy. Rows can be grouped using PartitionBy and ordered with OrderBy, and each row is assigned a group number starting from 1."
msgstr "הפצת השורות בתוך מחיצה למספר מוגדר של קבוצות (אריחים), בהתבסס על ה- OrderBy שצוין. ניתן לקבץ שורות באמצעות PartitionBy ולהזמין אותן באמצעות OrderBy, ולכל שורה מוקצה מספר קבוצה החל מ- 1."

#: App.LocalizationContent.expressionDesigner.expressionHelper.ntileEx
msgid "NTILE(bugets, PartitionBy := columns, OrderBy:= columns)"
msgstr "NTILE(באגטים, PartitionBy := עמודות, OrderBy:= עמודות)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.firstValueDesc
msgid "Returns the first value of the given column or expression within a partition, based on the specified OrderBy. Rows can be grouped using PartitionBy, ordered with OrderBy, and restricted to a specific range using Frame."
msgstr "הפונקציה מחזירה את הערך הראשון של העמודה או הביטוי הנתונים בתוך מחיצה, בהתבסס על ה- OrderBy שצוין. ניתן לקבץ שורות באמצעות PartitionBy, לסדר אותן באמצעות OrderBy ולהגביל לטווח ספציפי באמצעות Frame."

#: App.LocalizationContent.expressionDesigner.expressionHelper.firstValueEx
msgid "FIRSTVALUE(expression, PartitionBy := columns, OrderBy:= columns)"
msgstr "FIRSTVALUE (ביטוי, PartitionBy := עמודות, OrderBy:= עמודות)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.lastValueDesc
msgid "Returns the last value of the given column or expression within a partition, based on the specified OrderBy. Rows can be grouped using PartitionBy, ordered with OrderBy, and restricted to a specific range using Frame."
msgstr "החזרת הערך האחרון של העמודה או הביטוי הנתונים בתוך מחיצה, בהתבסס על ה- OrderBy שצוין. ניתן לקבץ שורות באמצעות PartitionBy, לסדר אותן באמצעות OrderBy ולהגביל לטווח ספציפי באמצעות Frame."

#: App.LocalizationContent.expressionDesigner.expressionHelper.lastValueEx
msgid "LASTVALUE(expression, PartitionBy := columns, OrderBy:= columns)"
msgstr "LASTVALUE(ביטוי, PartitionBy := עמודות, OrderBy:= עמודות)"

