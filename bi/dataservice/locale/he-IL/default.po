msgid "Computes continuous percentile values using linear interpolation over ordered data."
msgstr "מחשב ערכי אחוזון רציף באמצעות אינטרפולציה ליניארית על נתונים מסודרים."

#: App.LocalizationContent.expressionDesigner.expressionHelper.percentileCountEx
msgid "PERCENTILECOUNT(fraction, expression)"
