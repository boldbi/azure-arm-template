#: App.LocalizationContent.itemPanel.widgetDescription.columnChartDesc
msgid "Compare values for a set of unordered items across categories using vertical bars arranged horizontally."
msgstr "Comparez les valeurs d’un ensemble d’articles non ordonnés dans différentes catégories à l’aide de barres verticales disposées horizontalement."

#: App.LocalizationContent.itemPanel.widgetDescription.barChartDesc
msgid "Compare values for a set of unordered items across categories using horizontal bars arranged vertically."
msgstr "Comparez les valeurs d’un ensemble d’articles non ordonnés dans toutes les catégories à l’aide de barres horizontales disposées verticalement."

#: App.LocalizationContent.itemPanel.widgetDescription.stackedColumnDesc
msgid "Compare multiple measures using bars stacked vertically."
msgstr "Comparez plusieurs mesures à l’aide de barres empilées verticalement."

#: App.LocalizationContent.itemPanel.widgetDescription.stackedBarDesc
msgid "Compare multiple measures using bars stacked horizontally."
msgstr "Comparez plusieurs mesures à l’aide de barres empilées horizontalement."

#: App.LocalizationContent.itemPanel.widgetDescription.percentStackedBarDesc
msgid "Compare multiple measures as parts of a whole using bars stacked horizontally."
msgstr "Comparez plusieurs mesures comme les parties d’un tout à l’aide de barres empilées horizontalement."

#: App.LocalizationContent.itemPanel.widgetDescription.percentStackedColumnDesc
msgid "Compare multiple measures as parts of a whole using bars stacked vertically."
msgstr "Comparez plusieurs mesures comme les parties d’un tout à l’aide de barres empilées verticalement."

#: App.LocalizationContent.itemPanel.widgetDescription.gridDesc
msgid "Display tabular data with options to sort items."
msgstr "Affichez des données tabulaires avec des options pour trier les éléments."

#: App.LocalizationContent.itemPanel.widgetDescription.bubbleMapDesc
msgid "Showcase quantitative values encoded through bubble size ."
msgstr "Présentez des valeurs quantitatives encodées par la taille des bulles."

#: App.LocalizationContent.itemPanel.widgetDescription.choroplethMapDesc
msgid "Showcase quantitative values encoded through color scale."
msgstr "Présentez des valeurs quantitatives encodées par une échelle de couleurs."

#: App.LocalizationContent.itemPanel.widgetDescription.mapDesc
msgid "Showcase quantitative values encoded through color scale."
msgstr "Présentez des valeurs quantitatives encodées par une échelle de couleurs."

#: App.LocalizationContent.itemPanel.widgetDescription.bingmapsDesc
msgid "Showcase markers encoded through latitude and longitude."
msgstr "Mettez en valeur les marqueurs encodés par latitude et longitude."

#: App.LocalizationContent.itemPanel.widgetDescription.azuremapsDesc
msgid "Showcase markers encoded through latitude and longitude."
msgstr "Mettez en valeur les marqueurs encodés par latitude et longitude."

#: App.LocalizationContent.itemPanel.widgetDescription.treeMapDesc
msgid "Visualize large amounts of data as clustered rectangles with a color scale."
msgstr "Visualisez de grandes quantités de données sous forme de rectangles groupés avec une échelle de couleurs."

#: App.LocalizationContent.itemPanel.widgetDescription.cardDesc
msgid "Measure trends through key performance indicators like values and goals."
msgstr "Mesurez les tendances à l’aide d’indicateurs de performance clés tels que les valeurs et les objectifs."

#: App.LocalizationContent.itemPanel.widgetDescription.pieChartDesc
msgid "Showcase the proportions of each item's contribution to the total in the form of pie slices."
msgstr "Mettez en valeur les proportions de la contribution de chaque élément au total sous forme de parts de tarte."

#: App.LocalizationContent.itemPanel.widgetDescription.doughnutChartDesc
msgid "Showcase the proportions of each item's contribution to the total in the form of doughnut slices."
msgstr "Mettez en valeur les proportions de la contribution de chaque élément au total sous forme de tranches de beignets."

#: App.LocalizationContent.itemPanel.widgetDescription.pyramidChartDesc
msgid "Proportional comparison between values showcased in a progressively increasing manner."
msgstr "Comparaison proportionnelle entre les valeurs mises en valeur de manière progressivement croissante."

#: App.LocalizationContent.itemPanel.widgetDescription.funnelChartDesc
msgid "Proportional comparison between values showcased in a progressively decreasing manner."
msgstr "Comparaison proportionnelle entre les valeurs présentées de manière progressivement décroissante."

#: App.LocalizationContent.itemPanel.widgetDescription.areaChartDesc
msgid "Compare values for a set of unordered items across categories through filled curves ordered vertically."
msgstr "Comparez les valeurs d’un ensemble d’articles non ordonnés dans différentes catégories à l’aide de courbes remplies classées verticalement."

#: App.LocalizationContent.itemPanel.widgetDescription.stackedAreaDesc
msgid "Compare multiple measures through filled curves stacked vertically."
msgstr "Comparez plusieurs mesures à l’aide de courbes remplies empilées verticalement."

#: App.LocalizationContent.itemPanel.widgetDescription.percentStackedAreaDesc
msgid "Compare multiple measures as parts of a whole through filled curves stacked vertically."
msgstr "Comparez plusieurs mesures comme des parties d’un tout grâce à des courbes remplies empilées verticalement."

#: App.LocalizationContent.itemPanel.widgetDescription.lineChartDesc
msgid "Showcase trends for analysis over time with data points connected using straight lines."
msgstr "Présentez les tendances à analyser au fil du temps avec des points de données reliés par des lignes droites."

#: App.LocalizationContent.itemPanel.widgetDescription.splineChartDesc
msgid "Showcase trends for analysis over time with data points connected using splines."
msgstr "Présentez les tendances à analyser au fil du temps à l’aide de points de données connectés à l’aide de splines."

#: App.LocalizationContent.itemPanel.widgetDescription.splineAreaChartDesc
msgid "Compare values for a set of unordered items across categories through filled curves."
msgstr "Comparez les valeurs d’un ensemble d’articles non ordonnés dans différentes catégories à l’aide de courbes remplies."

#: App.LocalizationContent.itemPanel.widgetDescription.comboBoxDesc
msgid "Filter based on one or more items selected in a drop-down list."
msgstr "Filtrez en fonction d’un ou plusieurs éléments sélectionnés dans une liste déroulante."

#: App.LocalizationContent.itemPanel.widgetDescription.listBoxDesc
msgid "Filter based on single or multiple items selected in a list."
msgstr "Filtrez en fonction d’un ou de plusieurs éléments sélectionnés dans une liste."

#: App.LocalizationContent.itemPanel.widgetDescription.datePickerDesc
msgid "Filter based on a single date or a selected date range."
msgstr "Filtrez en fonction d’une seule date ou d’une plage de dates sélectionnée."

#: App.LocalizationContent.itemPanel.widgetDescription.rangeSliderDesc
msgid "Filter based on a value or date range set with sliders."
msgstr "Filtrez en fonction d’une valeur ou d’une plage de dates définie à l’aide de curseurs."

#: App.LocalizationContent.itemPanel.widgetDescription.labelDesc
msgid "Displays the given text."
msgstr "Affiche le texte donné."

#: App.LocalizationContent.itemPanel.widgetDescription.imageDesc
msgid "Displays a static image set."
msgstr "Affiche un jeu d’images statiques."

#: App.LocalizationContent.itemPanel.widgetDescription.heatMapDesc
msgid "Visualize large amounts of data as clustered rectangles with a color scale."
msgstr "Visualisez de grandes quantités de données sous forme de rectangles groupés avec une échelle de couleurs."

#: App.LocalizationContent.itemPanel.widgetDescription.gaugeDesc
msgid "Measure trends through key performance indicators like values and goals."
msgstr "Mesurez les tendances à l’aide d’indicateurs de performance clés tels que les valeurs et les objectifs."

#: App.LocalizationContent.itemPanel.widgetDescription.pivotViewDesc
msgid "Display summarized data in cross tabular format."
msgstr "Affichez les données résumées au format tabulaire croisé."

#: App.LocalizationContent.itemPanel.widgetDescription.kpiCardDesc
msgid "Evaluates actual data with target/thershold and displays the trend of actual data."
msgstr "Évalue les données réelles avec target/thershold et affiche la tendance des données réelles."

#: App.LocalizationContent.itemPanel.widgetDescription.comboChartDesc
msgid "Compare values across categories from different data sets using multiple chart types and a secondary axis."
msgstr "Comparez les valeurs entre les catégories de différents ensembles de données à l’aide de plusieurs types de graphiques et d’un axe secondaire."

#: App.LocalizationContent.itemPanel.widgetDescription.bubbleChartDesc
msgid "Compare and depict relationships between variables by means of positioning and proportions of the size of the bubbles/circles."
msgstr "Comparer et représenter les relations entre les variables au moyen du positionnement et des proportions de la taille des bulles/cercles."

#: App.LocalizationContent.itemPanel.widgetDescription.scatterChartDesc
msgid "Plot the relationship between two numeric variables."
msgstr "Tracez la relation entre deux variables numériques."

#: App.LocalizationContent.itemPanel.widgetDescription.radarPolarChartDesc
msgid "Display multivariate data in the form of a two-dimensional chart using three or more quantitative variables."
msgstr "Affichez des données multivariées sous la forme d’un graphique bidimensionnel à l’aide de trois variables quantitatives ou plus."

#: App.LocalizationContent.itemPanel.widgetDescription.rangeNavigatorDesc
msgid "Filter based on the selected date range."
msgstr "Filtrez en fonction de la plage de dates sélectionnée."

#: App.LocalizationContent.itemPanel.widgetDescription.numberCardDesc
msgid "Visualize the numeric value of the configured field."
msgstr "Visualisez la valeur numérique du champ configuré."

#: App.LocalizationContent.itemPanel.widgetDescription.richTextEditorDesc
msgid "Displays the given text with inline toolbar."
msgstr "Affiche le texte donné avec la barre d’outils en ligne."

#: App.LocalizationContent.itemPanel.widgetDescription.combineWidgetDesc
msgid "Combines multiple widgets."
msgstr "Combine plusieurs widgets."

#: App.LocalizationContent.itemPanel.widgetDescription.popDesc
msgid "Filter based on Date Ranges selected."
msgstr "Filtrez en fonction des plages de dates sélectionnées."

#: App.LocalizationContent.itemPanel.widgetDescription.lineDesc
msgid "Separate the widgets."
msgstr "Séparez les widgets."

#: App.LocalizationContent.itemPanel.widgetDescription.dateBucketDesc
msgid "Used to change the date format dynamically for the connected widgets."
msgstr "Utilisé pour modifier dynamiquement le format de date des widgets connectés."

#: App.LocalizationContent.itemPanel.widgetDescription.textFilterDesc
msgid "Filter based on the search performed in the text box."
msgstr "Filtrez en fonction de la recherche effectuée dans la zone de texte."

#: App.LocalizationContent.itemPanel.widgetDescription.tabWidgetDesc
msgid "Combine multiple widgets within tabs."
msgstr "Combinez plusieurs widgets dans des onglets."

#: App.LocalizationContent.itemPanel.widgetDescription.buttonDesc
msgid "Button"
msgstr "Bouton"

#: App.LocalizationContent.itemPanel.widgetDescription.qaDesc
msgid "Transform your questions into insightful charts."
msgstr "Transformez vos questions en graphiques perspicaces."

