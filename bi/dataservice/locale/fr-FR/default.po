msgid "Returns a numeric value representing the month part of the date resulting from specified date expression."
msgstr "Renvoie une valeur numérique représentant la partie mensuelle de la date résultant de l’expression de date spécifiée."

#: App.LocalizationContent.expressionDesigner.expressionHelper.monthEx
msgid "MONTH(date_expression)"
msgstr "MOIS(date_expression)"

