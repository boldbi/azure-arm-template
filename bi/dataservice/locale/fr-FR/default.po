msgid "Returns the current date and time."
msgstr "Renvoie la date et l’heure actuelles."

#: App.LocalizationContent.expressionDesigner.expressionHelper.nowEx
msgid "NOW()"
msgstr "MAINTENANT()"

#: App.LocalizationContent.expressionDesigner.expressionHelper.todayDesc
msgid "Returns the current date."
msgstr "Renvoie la date du jour."

#: App.LocalizationContent.expressionDesigner.expressionHelper.todayEx
msgid "TODAY()"
