msgid "DATENAME(datepart, date_expression)"
msgstr "DATENAME(datepart, date_expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.datePartDesc
msgid "Returns an integer value representing the specified date part of the given date expression."
msgstr "Renvoie une valeur entière représentant la partie date spécifiée de l’expression de date donnée."

#: App.LocalizationContent.expressionDesigner.expressionHelper.datePartEx
msgid "DATEPART(datepart, date_expression)"
msgstr "DATEPART(datepart, date_expression)"

