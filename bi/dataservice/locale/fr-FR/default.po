msgid "Returns a numeric value representing the day part of the specified date."
msgstr "Renvoie une valeur numérique représentant la partie jour de la date spécifiée."

#: App.LocalizationContent.expressionDesigner.expressionHelper.dayEx
msgid "DAY(date_expression)"
msgstr "JOUR(date_expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.dayDiffDesc
msgid "Returns a numeric value representing the difference between two specified dates."
msgstr "Renvoie une valeur numérique représentant la différence entre deux dates spécifiées."

#: App.LocalizationContent.expressionDesigner.expressionHelper.dayDiffEx
msgid "DAYDIFF(date_expression, date_expression)"
msgstr "DAYDIFF(date_expression, date_expression)"

