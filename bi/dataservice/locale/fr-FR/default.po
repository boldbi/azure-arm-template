msgid "Returns the date subtracted from the specified date."
msgstr "Renvoie la date soustraite de la date spécifiée."

#: App.LocalizationContent.expressionDesigner.expressionHelper.dateSubEx
msgid "DATESUB(numeric_expression, date_expression)"
msgstr "DATESUB(numeric_expression, date_expression)"

