msgid "Returns the tangent of the given numeric expression."
msgstr "Renvoie la tangente de l’expression numérique donnée."

#: App.LocalizationContent.expressionDesigner.expressionHelper.tanEx
msgid "TAN(numeric_expression)"
msgstr "TAN(numeric_expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.ifDesc
msgid "Returns either true part or false part, depending upon the evaluation of the expression."
msgstr "Renvoie soit true part, soit false part, selon l’évaluation de l’expression."

#: App.LocalizationContent.expressionDesigner.expressionHelper.ifEx
msgid "IF(expression, true_part, false_part)"
msgstr "IF(expression, true_part, false_part)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.ifNullDesc
msgid "If the expression is numeric/string/date, returns the first expression. If the first expression is NULL, returns the second expression."
msgstr "Si l’expression est numérique/chaîne/date, renvoie la première expression. Si la première expression est NULL, renvoie la seconde."

#: App.LocalizationContent.expressionDesigner.expressionHelper.ifNullEx
msgid "IFNULL(expression1,expression2)"
msgstr "IFNULL(expression1,expression2)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.isNotNullDesc
msgid "If the numeric/ string / date_expression is NULL, returns a string representing false, otherwise represents true."
msgstr "Si le numérique/chaîne/date_expression est NULL, renvoie une chaîne représentant false, sinon représente true."

#: App.LocalizationContent.expressionDesigner.expressionHelper.isNotNullEx
msgid "ISNOTNULL(expression)"
msgstr "ISNOTNULL(expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.isNullDesc
msgid "If the numeric/string/date_expression is NULL, returns a string representing true, otherwise represents false."
msgstr "Si le numérique/chaîne/date_expression est NULL, renvoie une chaîne représentant true, sinon représente false."

#: App.LocalizationContent.expressionDesigner.expressionHelper.isNullEx
msgid "ISNULL(expression)"
msgstr "ISNULL(expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.andDesc
msgid "Returns true if both the expressions evaluates to true."
msgstr "Renvoie true si les deux expressions ont la valeur true."

#: App.LocalizationContent.expressionDesigner.expressionHelper.andEx
msgid "(expression1) AND (expression2)"
msgstr "(expression1) ET (expression2)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.notDesc
msgid "Returns the reversal logical value of the expression being evaluated."
msgstr "Renvoie la valeur logique d’inversion de l’expression évaluée."

#: App.LocalizationContent.expressionDesigner.expressionHelper.notEx
msgid "NOT(expression)"
msgstr "NOT(expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.orDesc
msgid "Returns true if any of the expressions evaluates to true."
msgstr "Renvoie true si l’une des expressions est évaluée à true."

#: App.LocalizationContent.expressionDesigner.expressionHelper.orEx
msgid "(expression1) OR (expression2)"
msgstr "(expression1) OU (expression2)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.dateAddDesc
msgid "Adds a time/date interval to the specified date."
msgstr "Ajoute un intervalle de temps/date à la date spécifiée."

#: App.LocalizationContent.expressionDesigner.expressionHelper.dateAddEx
msgid "DATEADD(datepart, numeric_expression, date_expression)"
msgstr "DATEADD(datepart, numeric_expression, date_expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.dateDiffDesc
msgid "Returns the difference between two specified dates."
msgstr "Renvoie la différence entre deux dates spécifiées."

#: App.LocalizationContent.expressionDesigner.expressionHelper.dateDiffEx
msgid "DATEDIFF(date_part, start_date, end_date)"
msgstr "DATEDIFF(date_part, start_date, end_date)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.dateNameDesc
msgid "Returns a string representing the specified datepart of the given date expression."
msgstr "Renvoie une chaîne représentant la partie de date spécifiée de l’expression de date donnée."

