#: App.LocalizationContent.expressionDesigner.expressionHelper.absDesc
msgid "Returns the absolute value of the given expression."
msgstr "Renvoie la valeur absolue de l’expression donnée."

#: App.LocalizationContent.expressionDesigner.expressionHelper.absEx
msgid "ABS(numeric_expression)"
msgstr "ABS(numeric_expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.acosDesc
msgid "Returns the inverse cosine (also known as arccosine) of the given numeric expression. Value should be between -1 and +1."
msgstr "Renvoie le cosinus inverse (également appelé arccosinus) de l’expression numérique donnée. La valeur doit être comprise entre -1 et +1."

#: App.LocalizationContent.expressionDesigner.expressionHelper.acosEx
msgid "ACOS(numeric_expression)"
msgstr "ACOS(numeric_expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.asinDesc
msgid "Returns the inverse sine (also known as arcsine) of the given numeric expression. Value should be between - 1 and +1."
msgstr "Renvoie le sinus inverse (également appelé arcsinus) de l’expression numérique donnée. La valeur doit être comprise entre - 1 et +1."

#: App.LocalizationContent.expressionDesigner.expressionHelper.asinEx
msgid "ASIN(numeric_expression)"
msgstr "ASIN(numeric_expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.atanDesc
msgid "Returns the inverse tangent (also known as arctangent) of the given numeric expression."
msgstr "Renvoie la tangente inverse (également appelée tangente arc) de l’expression numérique donnée."

#: App.LocalizationContent.expressionDesigner.expressionHelper.atanEx
msgid "ATAN(numeric_expression)"
msgstr "ATAN(numeric_expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.cosDesc
msgid "Returns the cosine of the angle specified in radians of the given expression."
msgstr "Renvoie le cosinus de l’angle spécifié en radians de l’expression donnée."

#: App.LocalizationContent.expressionDesigner.expressionHelper.cosEx
msgid "COS(numeric_expression)"
msgstr "COS(numeric_expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.degDesc
msgid "Returns the angle in degrees for the one specified in radians of the given numeric expression."
msgstr "Renvoie l’angle en degrés de celui spécifié en radians de l’expression numérique donnée."

#: App.LocalizationContent.expressionDesigner.expressionHelper.degEx
msgid "DEGREES(numeric_expression)"
msgstr "DIPLÔME(numeric_expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.expDesc
msgid "Returns the exponential value of the given expression."
msgstr "Renvoie la valeur exponentielle de l’expression donnée."

#: App.LocalizationContent.expressionDesigner.expressionHelper.expEx
msgid "EXP(numeric_expression)"
msgstr "EXP(numeric_expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.logDesc
msgid "Returns the logarithm of the given expression to the specified base."
msgstr "Renvoie le logarithme de l’expression donnée à la base spécifiée."

#: App.LocalizationContent.expressionDesigner.expressionHelper.logEx
msgid "LOG(numeric_expression)"
msgstr "JOURNAL(numeric_expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.piDesc
msgid "Returns the constant value of PI."
msgstr "Renvoie la valeur constante de PI."

#: App.LocalizationContent.expressionDesigner.expressionHelper.piEx
msgid "PI()"
msgstr "PI()"

#: App.LocalizationContent.expressionDesigner.expressionHelper.powerDesc
msgid "Returns the value of the given expression (expression1) to the specified power (expression2)."
msgstr "Renvoie la valeur de l’expression donnée (expression1) à la puissance spécifiée (expression2)."

#: App.LocalizationContent.expressionDesigner.expressionHelper.powerEx
msgid "POWER(numeric_expression, numeric_expression)"
msgstr "PUISSANCE(numeric_expression, numeric_expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.percentageDesc
msgid "Returns the percentage value for each row from the grand total of the given column."
msgstr "Renvoie la valeur en pourcentage de chaque ligne à partir du total général de la colonne donnée."

#: App.LocalizationContent.expressionDesigner.expressionHelper.percentageEx
msgid "TOTALPERCENTAGE(numeric_expression)"
msgstr "TOTALPOURCENTAGE(numeric_expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.radDesc
msgid "Returns the angle in radians for the one specified in degrees in the given numeric expression."
msgstr "Renvoie l’angle en radians pour celui spécifié en degrés dans l’expression numérique donnée."

#: App.LocalizationContent.expressionDesigner.expressionHelper.radEx
msgid "RADIANS(numeric_expression)"
msgstr "RADIANS(numeric_expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.roundDesc
msgid "Returns a rounded value."
msgstr "Renvoie une valeur arrondie."

#: App.LocalizationContent.expressionDesigner.expressionHelper.roundEx
msgid "ROUND(numeric_expression)"
msgstr "ROND(numeric_expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.signDesc
msgid "Returns a value representing the positive (+1), zero(0), or negative (-1) sign of the given numeric expression."
msgstr "Renvoie une valeur représentant le signe positif (+1), zéro(0) ou négatif (-1) de l’expression numérique donnée."

#: App.LocalizationContent.expressionDesigner.expressionHelper.signEx
msgid "SIGN(numeric_expression)"
msgstr "SIGNE(numeric_expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.sinDesc
msgid "Returns the sine of the angle specified in radians of the given expression."
msgstr "Renvoie le sinus de l’angle spécifié en radians de l’expression donnée."

#: App.LocalizationContent.expressionDesigner.expressionHelper.sinEx
msgid "SIN(numeric_expression)"
msgstr "SANS(numeric_expression)"

#: App.LocalizationContent.expressionDesigner.expressionHelper.sqrtDesc
msgid "Returns the square root of the given numeric expression."
msgstr "Renvoie la racine carrée de l’expression numérique donnée."

#: App.LocalizationContent.expressionDesigner.expressionHelper.sqrtEx
msgid "SQRT(numeric_expression)"
msgstr "SQRT(numeric_expression)"

