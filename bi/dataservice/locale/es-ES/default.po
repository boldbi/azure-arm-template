msgid "Name should not contain spaces and special characters"
msgstr "El nombre no debe contener espacios ni caracteres especiales"

#: App.LocalizationContent.parameterMessages.changeParameter
msgid "Changing the datatype will discard changes made to the available and default values. Do you want to change the datatype anyway?"
msgstr "Al cambiar el tipo de datos, se descartarán los cambios realizados en los valores disponibles y predeterminados. ¿Desea cambiar el tipo de datos de todos modos?"

#: App.LocalizationContent.parameterMessages.multilevelCannotIncludeNull
msgid "A multi-value parameter cannot include null values"
msgstr "Un parámetro de varios valores no puede incluir valores nulos"

#: App.LocalizationContent.parameterMessages.multipleValues
msgid "Multiple default values were specified. The parameter does not allow multiple values."
msgstr "Se especificaron varios valores predeterminados. El parámetro no permite varios valores."

#: App.LocalizationContent.parameterMessages.nullCheck
msgid "Available or Default values might contains null value, Do you want to check the allow null value?"
msgstr "Los valores disponibles o predeterminados pueden contener un valor nulo, ¿desea comprobar el valor nulo permitido?"

#: App.LocalizationContent.parameterMessages.blankCheck
msgid "Available or Default values might contains blank value, Do you want to check the allow blank value?"
msgstr "Los valores disponibles o predeterminados pueden contener un valor en blanco, ¿desea comprobar el valor en blanco permitido?"

#: App.LocalizationContent.relativeDateMessages.itemExist
msgid "The relative date range that you are trying to add already exists."
msgstr "El intervalo de fechas relativo que está intentando agregar ya existe."

#: App.LocalizationContent.relativeDateMessages.relativeRangeNotEmpty
msgid "Relative range name should not empty"
msgstr "El nombre del rango relativo no debe vaciarse"

#: App.LocalizationContent.relativeDateMessages.startDateNotLessEndDate
msgid "Start date should not be lesser than End date."
msgstr "La fecha de inicio no debe ser inferior a la fecha de finalización."

#: App.LocalizationContent.relativeDateMessages.dateNotEmpty
msgid "Start and End date value should not be empty."
msgstr "El valor de la fecha de inicio y finalización no debe estar vacío."

#: App.LocalizationContent.relativeDateMessages.relativeDatesExist
msgid "The Relative dates applied for the Value Column section. So, it can not be bound in the Display column section. Please remove Relative dates from the Value section to add the Display column."
msgstr "Las fechas relativas se aplican a la sección Columna de valor. Por lo tanto, no se puede enlazar en la sección Mostrar columna. Elimine las fechas relativas de la sección Valor para agregar la columna Mostrar."

#: App.LocalizationContent.relativeDateMessages.displayColumnBinded
msgid "The Display column is configured. So, it can not be added as Relative dates. Remove the bound value from the Display column to add the Relative dates."
msgstr "La columna Mostrar está configurada. Por lo tanto, no se puede agregar como fechas relativas. Quite el valor enlazado de la columna Mostrar para agregar las fechas relativas."

