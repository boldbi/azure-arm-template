msgid "MySQL does not support the FULL OUTER JOIN"
msgstr "MySQL no admite la UNIÓN EXTERNA COMPLETA"

#: App.LocalizationContent.alertWindowMesages.joinMessageGoogle
msgid "Google Big Query does not support the FULL OUTER JOIN"
msgstr "Google Big Query no es compatible con la UNIÓN EXTERNA COMPLETA"

#: App.LocalizationContent.alertWindowMesages.joinMessageAzureDataExplorer
msgid "Azure Data Explorer does not support the CROSS JOIN"
msgstr "Azure Data Explorer no admite CROSS JOIN"

